      {"event": "UserPromptSubmit"},
      {"event": "PostToolUse", "toolName": "Bash"},
      {"event": "Stop"},
      {"event": "SessionEnd", "reason": "prompt_input_exit"}
    ],
    "permission": [
      {"event": "UserPromptSubmit"},
      {"event": "PermissionRequest", "toolName": "Bash"},
      {"event": "Notification", "notificationType": "permission_prompt"}
    ],
