{
  "providerVersion": "2.1.210 (Claude Code)",
  "scenarios": {
    "newThenExit": [
      {"event": "SessionStart", "source": "startup"},
      {"event": "SessionEnd", "reason": "prompt_input_exit"}
    ],
    "resumeThenExit": [
      {"event": "SessionStart", "source": "resume"},
      {"event": "SessionEnd", "reason": "prompt_input_exit"}
    ],
    "inTerminalResume": [
      {"event": "SessionStart", "source": "resume", "session": "A"},
      {"event": "SessionEnd", "reason": "resume", "session": "A"},
      {"event": "SessionStart", "source": "resume", "session": "B"},
      {"event": "SessionEnd", "reason": "prompt_input_exit", "session": "B"}
    ],
    "successfulTurn": [
