      "userLevelHookInstallationRequired": true
    },
    "exactAttach": {
      "paneArgvIncludedShortRuntimeId": true,
      "additionalHookObserved": false,
      "ctrlZClosedAttachWindow": true,
      "backgroundRuntimeSurvived": true
    },
    "agentViewDisabled": {
